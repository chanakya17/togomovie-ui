#!/bin/bash
# togomovie-ui post-merge hook
# Fires after: git pull, git merge
# Only regenerates SYSTEM.md when merging into main or master.

CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

if [[ "$CURRENT_BRANCH" != "main" && "$CURRENT_BRANCH" != "master" ]]; then
  exit 0
fi

COMMIT_MSG=$(git log -1 --pretty=%B)
if echo "$COMMIT_MSG" | grep -q "\[skip ci\]"; then
  exit 0
fi

CHANGED=$(git diff ORIG_HEAD HEAD --name-only 2>/dev/null)

if echo "$CHANGED" | grep -qE "\.(ts|tsx)$"; then
  SERVICE_NAME=$(basename "$(pwd)")
  echo "$SERVICE_NAME: source files merged into $CURRENT_BRANCH — updating SYSTEM.md..."
  cd ..
  bash togomovie-docs/scripts/update-system-doc.sh
fi
